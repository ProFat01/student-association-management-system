# Copy to .env and fill in real values. Never commit the real .env file.

# Copy to .env and fill in real values. Never commit the real .env file.
#
# Every variable below is read somewhere in config/settings/*.py — none
# are aspirational. (An earlier version of this file documented
# DATABASE_URL as if it did something while no settings file actually
# read it; that's been fixed — see PRODUCTION_DEPLOYMENT.md "Environment
# variables audit" if you're curious about the history.)

# --- Core (used in every environment) ---
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost

# Parsed by django-environ's env.db(). Leave commented out to fall back
# to a local SQLite file (config/settings/development.py and
# production.py both define their own sensible default path). Uncomment
# to switch databases entirely, including the eventual move to Postgres:
#   DATABASE_URL=postgres://user:password@host:5432/sams
#
# Important: leave this line commented out, not set to an empty value —
# django-environ's env.db(default=...) only falls back to its default
# when the variable is entirely absent from the environment. A present-
# but-empty DATABASE_URL= is parsed as an (invalid) URL instead of
# triggering the default, which breaks startup entirely. Caught and
# fixed during this project's own production audit — see
# PRODUCTION_DEPLOYMENT.md "Environment variables audit".
# DATABASE_URL=

# Slug of the Association this deployment serves (core/models.py).
DEFAULT_ASSOCIATION_SLUG=msa

# --- Development only ---
DEBUG=True

# --- Production only (config/settings/production.py) ---
# All required for a real deploy; see PRODUCTION_DEPLOYMENT.md for the
# full checklist and what happens if any of these are left unset.

# SQLite-specific convenience alternative to DATABASE_URL — easier to
# point at a specific absolute path on PythonAnywhere than to build a
# sqlite:/// URL by hand. Ignored if DATABASE_URL is also set.
DJANGO_DB_PATH=/home/yourusername/sams/db.sqlite3

# Must include the scheme. CRITICAL on PythonAnywhere — without this,
# every POST request (registration, voting, the contact form, admin
# logins) fails CSRF validation. See PRODUCTION_DEPLOYMENT.md "Reverse
# proxy / HTTPS".
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com

# Set to False only temporarily while first verifying a deploy without
# HTTPS configured yet; must be True (the default) for real traffic.
SECURE_SSL_REDIRECT=True

# name:email pairs, comma-separated. Unhandled view exceptions are
# emailed here (see LOGGING in production.py). Leave unset and server
# errors fail silently from your perspective — you'd only find out from
# a user reporting it.
DJANGO_ADMINS=Admin Name:admin@example.com

# SMTP, used for both DJANGO_ADMINS error emails and any future
# membership-notification email features.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
